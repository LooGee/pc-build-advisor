# ─── 필수 ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...          # platform.openai.com 에서 발급

# ─── 선택 (Claude fallback — 없어도 동작) ───────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── 인프라 ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1

# ─── LLM 설정 ──────────────────────────────────────────
LLM_PROVIDER=openai

# 역할별 모델 (변경 가능)
LLM_MODEL_ANALYSIS=gpt-4o-mini   # 요구사항 분석: 비용·성능 균형
LLM_MODEL_COMPLEX=gpt-4o         # 복잡한 추론 / 재시도: 최고 품질

DAILY_BUDGET_USD=50.0
