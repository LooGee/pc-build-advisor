# ─── 데이터베이스 ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@postgres:5432/pc_build_db

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── 보안 키 (랜덤 문자열 32자 이상) ───────────────────
SECRET_KEY=your-secret-key-here

# ─── LLM API 키 ────────────────────────────────────────
OPENAI_API_KEY=sk-...           # 필수 | platform.openai.com 에서 발급
# ANTHROPIC_API_KEY=sk-ant-...  # 선택 | Claude fallback 원할 때만

# ─── LLM 모델 설정 ─────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL_ANALYSIS=gpt-4o-mini  # 요구사항 분석 (비용·성능 균형)
LLM_MODEL_COMPLEX=gpt-4o        # 복잡한 추론 / 재시도 (최고 품질)

# ─── 서비스 설정 ────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000
